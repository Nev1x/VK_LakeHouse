# .env.example — шаблон окружения LakeHouse-стека LoftNavigator (фича 001).
# Скопируй в .env и подставь СВОИ значения (например: openssl rand -hex 24).
# Значения ниже — НЕФУНКЦИОНАЛЬНЫЕ плейсхолдеры, стек с ними поднимать нельзя.
# Файл .env в git НЕ попадает (см. .gitignore); здесь — только раздельные переменные,
# без DSN, где логин и пароль встроены прямо в URL (такие URL secret-скан блокирует).

# --- MinIO (объектное хранилище, root-креды; ими же пока ходит Trino и loader 002) ---
MINIO_ROOT_USER=changeme_local_dev
MINIO_ROOT_PASSWORD=changeme_local_dev

# --- PostgreSQL (JDBC-каталог Iceberg; наружу НЕ публикуется) ---
POSTGRES_USER=changeme_local_dev
POSTGRES_PASSWORD=changeme_local_dev
POSTGRES_DB=iceberg_catalog

# --- Trino (SQL-движок; password-аутентификация, FR-015) ---
TRINO_USER=loftnav
TRINO_PASSWORD=changeme_local_dev
# shared-secret внутренней коммуникации Trino (обязателен при auth); задай openssl rand -hex 32
TRINO_INTERNAL_SECRET=changeme_local_dev
# пароль self-signed keystore Trino HTTPS (password auth требует TLS); задай openssl rand -hex 24
TRINO_KEYSTORE_PASSWORD=changeme_local_dev

# --- Grafana (UI-обвязка под фичу 005; не admin/admin) ---
GRAFANA_ADMIN_USER=changeme_local_dev
GRAFANA_ADMIN_PASSWORD=changeme_local_dev

# --- Публикация host-портов (только на 127.0.0.1; переопределяемы) ---
GRAFANA_PORT=3000
TRINO_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Единый TZ для сопоставимости логов (NFR-006) ---
TZ=UTC
